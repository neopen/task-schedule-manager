# ============================================================
# MANIFEST.in for Neotask
# ============================================================
# This file tells setuptools which additional files to include
# in the source distribution (sdist) and binary distribution (wheel)
# ============================================================

# ============================================================
# Include core package files
# ============================================================
include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml
include requirements.txt

# ============================================================
# Include package data
# ============================================================
# Web UI static files (HTML, CSS, JS)
recursive-include src/neotask/web/static *
recursive-include src/neotask/web/templates *

# Type hints for mypy
recursive-include src/neotask *.pyi

# ============================================================
# Include examples
# ============================================================
recursive-include examples *

# ============================================================
# Include tests
# ============================================================
recursive-include tests *

# ============================================================
# Include documentation
# ============================================================
recursive-include docs *

# ============================================================
# Include configuration files
# ============================================================
include .gitignore
include .pre-commit-config.yaml
include mkdocs.yml
include tox.ini

# ============================================================
# Exclude unnecessary files from distribution
# ============================================================
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude .DS_Store
global-exclude .vscode
global-exclude .idea
global-exclude .mypy_cache
global-exclude .pytest_cache
global-exclude .ruff_cache
global-exclude .coverage
global-exclude htmlcov
global-exclude *.egg-info
global-exclude .eggs
global-exclude dist
global-exclude build

# ============================================================
# Exclude development files
# ============================================================
prune .github
prune .vscode
prune .idea
prune .mypy_cache
prune .pytest_cache
prune .ruff_cache
prune htmlcov
prune dist
prune build
prune *.egg-info

# ============================================================
# Exclude virtual environments
# ============================================================
prune venv
prune env
prune .venv
prune .env